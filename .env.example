# ─────────────────────────────────────────────
# Vauxtra — Environment Configuration
# Copy to .env and customize as needed.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ─── Security ────────────────────────────────

# Secret key for encrypting provider credentials and signing sessions.
# Auto-generated on first run if left empty (stored in data/.secret_key).
# DO NOT CHANGE after adding providers — credentials will become unreadable.
SECRET_KEY=

# Password to protect the web interface.
# Leave empty → configure via Setup wizard on first launch.
# Set here → takes priority over wizard-configured password.
APP_PASSWORD=

# ─── General ─────────────────────────────────

# Timezone for scheduling and log timestamps
TZ=Europe/Paris

# Set to true when serving directly over HTTPS (not behind a reverse proxy)
HTTPS_ONLY=false

# Enable debug mode: exposes /api/docs (Swagger UI) and verbose logging
DEBUG=false

# ─── MCP Server ──────────────────────────────
# URL of this Vauxtra instance (used by the MCP server to call the API)
VAUXTRA_URL=http://localhost:8888

# API key for MCP server authentication (create one in Settings → API Keys)
VAUXTRA_API_KEY=

# ─── Network ─────────────────────────────────
# Comma-separated list of allowed CORS origins (leave empty for same-origin only)
# CORS_ORIGINS=http://localhost:5173,https://vauxtra.example.com

# ─── Docker ──────────────────────────────────
# Default Docker socket path (override if using a non-standard location)
# DOCKER_HOST=unix:///var/run/docker.sock
